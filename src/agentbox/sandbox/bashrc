# /home/agentbox/.bashrc -- agentbox sandbox shell config

# Skip non-interactive shells (e.g. agent tool-call subshells, scp).
[[ $- != *i* ]] && return

# History.
HISTSIZE=10000
HISTFILESIZE=20000
HISTCONTROL=ignoredups:erasedups
HISTTIMEFORMAT='%F %T  '
shopt -s histappend cmdhist checkwinsize
PROMPT_COMMAND='history -a'

# Color aliases.
alias ls='ls --color=auto'
alias ll='ls -lah --color=auto'
alias la='ls -A --color=auto'
alias l='ls -CF --color=auto'
alias grep='grep --color=auto'
alias egrep='egrep --color=auto'
alias fgrep='fgrep --color=auto'
alias diff='diff --color=auto'
alias ip='ip --color=auto'

# Navigation.
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Quality of life.
alias h='history'
alias df='df -h'
alias du='du -h'
alias free='free -h'
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline --graph --decorate -20'

# Editor / pager.
export EDITOR=nano
export VISUAL=nano
export PAGER=less
export LESS='-R -F -X --mouse'

# Less colors for man-style output.
export LESS_TERMCAP_md=$'\e[1;36m'
export LESS_TERMCAP_me=$'\e[0m'
export LESS_TERMCAP_us=$'\e[1;33m'
export LESS_TERMCAP_ue=$'\e[0m'
export LESS_TERMCAP_so=$'\e[1;44;33m'
export LESS_TERMCAP_se=$'\e[0m'

# Bash completion (provides git, docker, gh, ... completions).
if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
fi

# Git branch in prompt, when git ships its prompt helper.
if [ -f /usr/lib/git-core/git-sh-prompt ]; then
    . /usr/lib/git-core/git-sh-prompt
    export GIT_PS1_SHOWDIRTYSTATE=1
    export GIT_PS1_SHOWUNTRACKEDFILES=1
    export GIT_PS1_SHOWCOLORHINTS=1
    PS1='\[\e[1;35m\]agentbox\[\e[0m\] \[\e[1;34m\]\w\[\e[0;33m\]$(__git_ps1 " (%s)")\[\e[0m\] \$ '
else
    PS1='\[\e[1;35m\]agentbox\[\e[0m\] \[\e[1;34m\]\w\[\e[0m\] \$ '
fi

# Welcome banner -- top-level interactive shell only.
if [ "${SHLVL}" = "1" ] && [ -z "${AGENTBOX_BANNER_SHOWN}" ]; then
    export AGENTBOX_BANNER_SHOWN=1
    printf '\n'
    printf '  \e[1;35magentbox sandbox\e[0m  --  agent-isolation container with credential proxy\n\n'
    printf '  workspace:  %s    (host cwd)\n' "${PWD}"
    printf '  agent dirs: /home/agentbox/.pi      (always)\n'
    printf '              /home/agentbox/.claude  (if mounted)\n'
    printf '  network:    HTTPS via %s\n' "${HTTPS_PROXY:-(none)}"
    printf '              allowlist enforced; CONNECT, raw TCP, DNS exfil all blocked\n'
    printf '  agents:     pi, claude     (run them directly to start a session)\n'
    printf '  tools:      git gh rg fd jq yq tree nano less curl\n\n'
fi
